local Casserus = loadstring(game:HttpGet("https://raw.githubusercontent.com/casserus/roblox/main/ui"))()
local PlaceId = game.PlaceId
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local Lighting = game:GetService("Lighting")

-- [[ ID ของแมพ - ปรับตามจริงได้เลยครับ ]]
local LobbyID = 16825633506 
local isLobby = (PlaceId == LobbyID)

-- [[ สร้าง Window ]]
local Window = Casserus:Window("Marshmallow hub", isLobby and "Lobby Mode" or "Game Mode", Enum.KeyCode.RightControl)

-- ฟังก์ชันเช็คเสียงที่มาจากระบบ/ตัวเรา (Internal)
local function isInternal(obj)
    if obj:IsDescendantOf(game:GetService("CoreGui")) or obj:IsDescendantOf(lp.PlayerGui) then return true end
    if lp.Character and obj:IsDescendantOf(lp.Character) then return true end
    return false
end

-- ==========================================
-- 🏠 [ SECTION 1: LOBBY TAB ]
-- (จะโผล่มาเฉพาะตอนอยู่ Lobby)
-- ==========================================
if isLobby then
    local LobbyTab = Window:Tab("Lobby Utils")

    LobbyTab:Button("Auto Coffee Setup", function()
        local char = lp.Character
        if char then
            local hasCup = char:FindFirstChild("Coffee Cup")
            local CollectionService = game:GetService("CollectionService")
            for _, v in ipairs(CollectionService:GetTagged("coffee_giver")) do v.Enabled = not hasCup end
            for _, v in ipairs(CollectionService:GetTagged("coffee_fill")) do v.Enabled = hasCup end
        end
    end)
    
    LobbyTab:Button("Fast Leave", function()
        local rs = game:GetService("ReplicatedStorage")
        local leave = rs:FindFirstChild("Remotes") and rs.Remotes:FindFirstChild("LeaveButton")
        if leave then leave:FireServer() end
    end)
end

-- ==========================================
-- 👁️ [ SECTION 2: GAME TABS ]
-- (จะโผล่มาเฉพาะตอนเข้าเกมแล้ว)
-- ==========================================
if not isLobby then
    local DetectTab = Window:Tab("Detection")
    local VisualsTab = Window:Tab("Visuals")
    
    -- [[ ระบบตรวจจับเสียง ]]
    local soundEnabled = false
    local soundCooldowns = {}

    DetectTab:Toggle("Smart Sound Alert", false, function(state)
        soundEnabled = state
    end)

    task.spawn(function()
        while task.wait(0.5) do
            if soundEnabled then
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Sound") and obj.IsPlaying then
                        local n = obj.Name:lower()
                        -- รายการเสียงปลอดภัย (ไม่แจ้งเตือน)
                        local safe = {"spray", "flash", "click", "step", "walk", "run", "jump", "idle", "loop", "wind", "hum"}
                        local isSafe = false
                        for _, word in ipairs(safe) do if n:find(word) then isSafe = true break end end
                        
                        if not isSafe and not isInternal(obj) then
                            if not soundCooldowns[obj.SoundId] or (os.clock() - soundCooldowns[obj.SoundId] > 8) then
                                soundCooldowns[obj.SoundId] = os.clock()
                                game:GetService("StarterGui"):SetCore("SendNotification", {
                                    Title = "Sound detect",
                                    Text = "เจอเสียง: [" .. obj.Name .. "]",
                                    Duration = 5
                                })
                            end
                        end
                    end
                end
            end
        end
    end)

    -- [[ ระบบภาพ ]]
    VisualsTab:Toggle("Night Vision", false, function(state)
        Lighting.Ambient = state and Color3.new(1, 1, 1) or Color3.fromRGB(15, 15, 15)
        Lighting.Brightness = state and 2 or 1
    end)

    VisualsTab:Toggle("Remove Fog", false, function(state)
        Lighting.FogEnd = state and 999999 or 100
    end)
end

-- ==========================================
-- 🏃 [ SECTION 3: COMMON TAB ]
-- (ใช้ได้ทั้ง Lobby และในเกม)
-- ==========================================
local PlayerTab = Window:Tab("Player")

PlayerTab:Slider("Walk Speed", 16, 100, 16, function(value)
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        lp.Character.Humanoid.WalkSpeed = value
    end
end)

-- แจ้งเตือนสถานะการโหลด
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "Marshmallow hub",
    Text = isLobby and "ตรวจพบ: Lobby Mode" or "ตรวจพบ: Game Mode",
    Duration = 5
})
